# --- Market hours (24h format) ---
# DSE regular trading session is 10:00 to 14:20 local time.
MARKET_OPEN_TIME=10:00
MARKET_CLOSE_TIME=14:20
MARKET_TIMEZONE=Asia/Dhaka

# --- Backend server ---
BACKEND_PORT=4000

# --- Frontend dev-server port ---
FRONTEND_PORT=3000

# --- Database ---
DB_URL=postgresql://dse_user:dse_password@localhost:5433/dse_market?schema=public

# --- Postgres (consumed by docker-compose to provision the DB) ---
POSTGRES_USER=dse_user
POSTGRES_PASSWORD=dse_password
POSTGRES_DB=dse_market

# --- Frontend (Vite — exposed to the browser, must be VITE_-prefixed) ---
VITE_MARKET_OPEN_TIME=10:00
VITE_MARKET_CLOSE_TIME=14:20
VITE_MARKET_TIMEZONE=Asia/Dhaka
